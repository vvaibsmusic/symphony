# YouTube Data API v3 key (get from console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Spotify API (get from developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Viral detection thresholds
YT_VIRAL_GROWTH_FACTOR=10
SPOTIFY_VIRAL_POPULARITY_JUMP=20
SPOTIFY_MARKET=IN

# Turso Cloud SQLite (get from turso.tech dashboard)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here
